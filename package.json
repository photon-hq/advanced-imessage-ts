{
  "name": "advanced-imessage-ts",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "proto"],
  "engines": { "node": ">=18" },
  "scripts": {
    "generate": "PATH=./node_modules/.bin:$PATH buf generate",
    "build": "bun run generate && tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@protobuf-ts/runtime": "^2.9.6",
    "@protobuf-ts/runtime-rpc": "^2.9.6",
    "nice-grpc": "^2.1.11",
    "nice-grpc-common": "^2.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@bufbuild/buf": "^1.50.0",
    "@protobuf-ts/plugin": "^2.9.6",
    "@types/bun": "latest",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "ultracite": "7.3.2"
  }
}
